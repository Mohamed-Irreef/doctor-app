NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/nividoc
JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
CORS_ORIGIN=http://localhost:8081,http://localhost:5173,http://localhost:5174
GOOGLE_CLIENT_ID=replace_google_client_id
RAZORPAY_KEY_ID=replace_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_webhook_secret
CLOUDINARY_CLOUD_NAME=replace_cloud_name
CLOUDINARY_API_KEY=replace_api_key
CLOUDINARY_API_SECRET=replace_api_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_email
SMTP_PASS=replace_app_password
MAIL_FROM=NiviDoc <noreply@nividoc.com>
